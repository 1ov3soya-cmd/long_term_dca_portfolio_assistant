    "stock": {
      "buy_commission": 0.0003,
      "sell_commission": 0.0003,
      "sell_stamp_tax": 0.001,
      "slippage": 0.002
    }
  },
  "trading_rules": {
    "min_trade_lot": 100,
    "round_down_to_lot": true,
